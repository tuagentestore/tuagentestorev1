# ============================================================
# TUAGENTESTORE — Caddyfile
# Caddy maneja SSL automático (Let's Encrypt) + reverse proxy
# ============================================================

# ── APP Principal (Next.js) ──
tuagentestore.com {
    reverse_proxy app:3000

    # Security headers
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    # Gzip
    encode gzip

    # Webhooks entrantes (n8n)
    @webhooks path /webhooks/*
    handle @webhooks {
        reverse_proxy n8n:5678
    }

    # Logs
    log {
        output file /data/logs/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}

# ── WWW redirect ──
www.tuagentestore.com {
    redir https://tuagentestore.com{uri} permanent
}

# ── METABASE (BI Dashboard) ──
app.tuagentestore.com {
    reverse_proxy metabase:3000

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    encode gzip

    log {
        output file /data/logs/metabase-access.log {
            roll_size 10mb
            roll_keep 3
        }
    }
}

# ── N8N (subdominio) ──
n8n.tuagentestore.com, n8n.srv1565607.hstgr.cloud {
    reverse_proxy n8n:5678

    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Strict-Transport-Security "max-age=31536000"
        -Server
    }

    log {
        output file /data/logs/n8n-access.log {
            roll_size 10mb
            roll_keep 3
        }
    }
}
