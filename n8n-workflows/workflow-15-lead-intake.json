      "name": "Esperar 5 días",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [2640, 420]
    },
    {
      "parameters": {
        "jsCode": "const d = $('wf15-normalize').first().json;\n\nconst body = `\n<div style=\"font-family:Inter,system-ui,sans-serif;max-width:600px;margin:0 auto;background:#0a0f1e;color:#e2e8f0;padding:40px 32px;border-radius:16px\">\n  <div style=\"margin-bottom:32px\">\n    <span style=\"background:linear-gradient(135deg,#3b82f6,#6366f1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-weight:800;font-size:20px\">TuAgenteStore</span>\n  </div>\n  <h1 style=\"font-size:22px;font-weight:800;color:#f1f5f9;margin-bottom:12px\">Regalo para vos: diagnóstico gratuito</h1>\n  <p style=\"color:#94a3b8;line-height:1.7;margin-bottom:24px\">Hola ${d.first_name}, queremos ayudarte a descubrir exactamente cómo un agente IA puede resolver tu desafío de <strong style=\"color:#f1f5f9\">${d.problem_label}</strong>.</p>\n\n  <div style=\"background:linear-gradient(135deg,#1e3a5f,#1e1b4b);border:1px solid #3b82f6;border-radius:12px;padding:24px;margin-bottom:28px\">\n    <p style=\"font-weight:700;font-size:18px;color:#f1f5f9;margin-bottom:8px\">🎯 Diagnóstico IA gratuito (30 min)</p>\n    <p style=\"color:#94a3b8;font-size:14px;line-height:1.6\">Un especialista analiza tu operación actual y te muestra un roadmap personalizado de automatización. Sin compromiso.</p>\n    <ul style=\"color:#94a3b8;font-size:14px;padding-left:20px;margin-top:12px\">\n      <li>¿Qué procesos se pueden automatizar hoy?</li>\n      <li>¿Qué ahorro real genera el agente?</li>\n      <li>¿En cuánto tiempo lo tenés activo?</li>\n    </ul>\n  </div>\n\n  <a href=\"https://tuagentestore.com/empezar?problema=${d.problem_area}\" style=\"display:inline-block;background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;text-decoration:none;padding:14px 28px;border-radius:12px;font-weight:600;font-size:16px\">Quiero mi diagnóstico gratuito →</a>\n\n  <hr style=\"border:none;border-top:1px solid #1e293b;margin:36px 0\">\n  <p style=\"color:#475569;font-size:12px\">Último email de esta secuencia. Si no querés más info, respondé con \"cancelar\".</p>\n</div>\n`;\n\nreturn [{ json: { ...d, diagnostic_body: body } }];"
      },
