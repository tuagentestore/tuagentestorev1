            "Reserva ID": "={{ $json.body.reservation_id }}",
            "Nombre": "={{ $json.body.user_name }}",
            "Email": "={{ $json.body.user_email }}",
            "Teléfono": "={{ $json.body.phone }}",
            "Empresa": "={{ $json.body.company }}",
            "Agente": "={{ $json.body.agent_name || $json.body.agent_slug }}",
            "Plan": "={{ $json.body.plan_interest }}",
            "Fecha Preferida": "={{ $json.body.preferred_date }}",
            "Estado": "new"
          }
        },
        "options": {}
      },
      "id": "log-to-pipeline",
      "name": "Log en Reservations Pipeline",
      "type": "n8n-nodes-base.googleSheets",
