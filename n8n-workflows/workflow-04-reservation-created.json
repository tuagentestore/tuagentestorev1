        "emailType": "html",
        "message": "={{ `<!DOCTYPE html><html lang=\"es\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Reserva confirmada</title></head><body style=\"margin:0;padding:0;background:#f4f6fb;font-family:'Segoe UI',Arial,sans-serif;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f6fb;padding:32px 0;\"><tr><td align=\"center\"><table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,0.08);max-width:600px;\"><tr><td style=\"background:linear-gradient(135deg,#1e3a6e 0%,#2563eb 100%);padding:32px 40px;text-align:center;\"><img src='https://tuagentestore.com/logo-white.png' alt='TuAgente Store' width='160' style='display:block;margin:0 auto 16px;' onerror='this.style.display=&quot;none&quot;'><h1 style=\"color:#ffffff;margin:0;font-size:24px;font-weight:700;letter-spacing:-0.5px;\">Tu reserva fue confirmada</h1><p style=\"color:rgba(255,255,255,0.8);margin:8px 0 0;font-size:15px;\">Gracias por elegir TuAgente Store</p></td></tr><tr><td style=\"padding:32px 40px;\"><p style=\"color:#374151;font-size:16px;margin:0 0 8px;\">Hola <strong>` + ($json.body.user_name || 'allí') + `</strong>,</p><p style=\"color:#374151;font-size:15px;line-height:1.6;margin:0 0 24px;\">Recibimos tu solicitud. Nuestro equipo la revisará y te contactará en <strong>menos de 24 horas hábiles</strong>.</p><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f8faff;border:1px solid #e5e7eb;border-radius:8px;margin:0 0 24px;\"><tr><td style=\"padding:20px 24px;\"><p style=\"color:#6b7280;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;margin:0 0 12px;\">Resumen de tu reserva</p><table width=\"100%\"><tr><td style=\"padding:4px 0;color:#6b7280;font-size:14px;width:40%;\">Agente</td><td style=\"padding:4px 0;color:#111827;font-size:14px;font-weight:600;\">` + ($json.body.agent_name || $json.body.agent_slug || '—') + `</td></tr><tr><td style=\"padding:4px 0;color:#6b7280;font-size:14px;\">Plan</td><td style=\"padding:4px 0;color:#111827;font-size:14px;font-weight:600;\">` + ($json.body.plan_interest || 'Starter') + `</td></tr><tr><td style=\"padding:4px 0;color:#6b7280;font-size:14px;\">Empresa</td><td style=\"padding:4px 0;color:#111827;font-size:14px;font-weight:600;\">` + ($json.body.company || '—') + `</td></tr>` + ($json.body.preferred_date ? `<tr><td style=\"padding:4px 0;color:#6b7280;font-size:14px;\">Fecha preferida</td><td style=\"padding:4px 0;color:#111827;font-size:14px;font-weight:600;\">` + $json.body.preferred_date + `</td></tr>` : '') + `</table></td></tr></table><p style=\"color:#374151;font-size:14px;font-weight:600;margin:0 0 12px;\">¿Qué sigue?</p><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"padding:6px 0;\"><table><tr><td style=\"width:28px;height:28px;background:#2563eb;border-radius:50%;text-align:center;vertical-align:middle;\"><span style=\"color:#fff;font-size:13px;font-weight:700;\">1</span></td><td style=\"padding-left:12px;color:#374151;font-size:14px;\">Revisamos tu caso de uso</td></tr></table></td></tr><tr><td style=\"padding:6px 0;\"><table><tr><td style=\"width:28px;height:28px;background:#2563eb;border-radius:50%;text-align:center;vertical-align:middle;\"><span style=\"color:#fff;font-size:13px;font-weight:700;\">2</span></td><td style=\"padding-left:12px;color:#374151;font-size:14px;\">Coordinamos la configuración</td></tr></table></td></tr><tr><td style=\"padding:6px 0;\"><table><tr><td style=\"width:28px;height:28px;background:#2563eb;border-radius:50%;text-align:center;vertical-align:middle;\"><span style=\"color:#fff;font-size:13px;font-weight:700;\">3</span></td><td style=\"padding-left:12px;color:#374151;font-size:14px;\">Te enviamos el link de activación</td></tr></table></td></tr></table></td></tr><tr><td style=\"background:#f8faff;padding:24px 40px;border-top:1px solid #e5e7eb;\"><p style=\"color:#6b7280;font-size:13px;margin:0 0 4px;\">¿Tenés preguntas? Respondé este email o escribinos a</p><a href=\"mailto:hola@tuagentestore.com\" style=\"color:#2563eb;font-size:13px;font-weight:600;text-decoration:none;\">hola@tuagentestore.com</a><p style=\"color:#9ca3af;font-size:12px;margin:12px 0 0;\">© 2026 TuAgente Store · <a href=\"https://tuagentestore.com\" style=\"color:#9ca3af;\">tuagentestore.com</a></p></td></tr></table></td></tr></table></body></html>` }}",
        "options": {
          "fromEmail": "={{ $env.GMAIL_FROM }}",
          "fromName": "TuAgente Store"
        }
