        "emailType": "html",
        "message": "={{ `<!DOCTYPE html><html><body style=\"font-family:'Segoe UI',Arial,sans-serif;background:#f4f6fb;padding:32px;\"><table width=\"600\" style=\"background:#fff;border-radius:10px;padding:32px;margin:0 auto;box-shadow:0 2px 12px rgba(0,0,0,0.07);\"><tr><td><h2 style=\"color:#1e3a6e;margin:0 0 20px;\">Nueva reserva recibida</h2><table width=\"100%\" style=\"border-collapse:collapse;\"><tr><td colspan=\"2\" style=\"background:#f0f4ff;padding:8px 12px;font-size:12px;font-weight:700;color:#2563eb;text-transform:uppercase;border-radius:4px 4px 0 0;\">Datos del lead</td></tr><tr style=\"border-bottom:1px solid #e5e7eb;\"><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">Nombre</td><td style=\"padding:8px 12px;color:#111827;font-size:14px;font-weight:600;\">` + $json.body.user_name + `</td></tr><tr style=\"border-bottom:1px solid #e5e7eb;\"><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">Email</td><td style=\"padding:8px 12px;color:#2563eb;font-size:14px;\"><a href=\"mailto:` + $json.body.user_email + `\">` + $json.body.user_email + `</a></td></tr><tr style=\"border-bottom:1px solid #e5e7eb;\"><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">Teléfono</td><td style=\"padding:8px 12px;color:#111827;font-size:14px;\">` + ($json.body.phone || '—') + `</td></tr><tr style=\"border-bottom:1px solid #e5e7eb;\"><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">Empresa</td><td style=\"padding:8px 12px;color:#111827;font-size:14px;\">` + ($json.body.company || '—') + `</td></tr><tr style=\"border-bottom:1px solid #e5e7eb;\"><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">Industria</td><td style=\"padding:8px 12px;color:#111827;font-size:14px;\">` + ($json.body.industry || '—') + `</td></tr><tr><td colspan=\"2\" style=\"background:#faf5ff;padding:8px 12px;font-size:12px;font-weight:700;color:#7c3aed;text-transform:uppercase;border-radius:0;\">Solicitud</td></tr><tr style=\"border-bottom:1px solid #e5e7eb;\"><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">Agente</td><td style=\"padding:8px 12px;color:#111827;font-size:14px;font-weight:700;\">` + ($json.body.agent_name || $json.body.agent_slug) + `</td></tr><tr style=\"border-bottom:1px solid #e5e7eb;\"><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">Plan</td><td style=\"padding:8px 12px;color:#111827;font-size:14px;\">` + ($json.body.plan_interest || '—') + `</td></tr><tr style=\"border-bottom:1px solid #e5e7eb;\"><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">Fecha preferida</td><td style=\"padding:8px 12px;color:#111827;font-size:14px;\">` + ($json.body.preferred_date || 'No especificó') + `</td></tr><tr style=\"border-bottom:1px solid #e5e7eb;\"><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">Caso de uso</td><td style=\"padding:8px 12px;color:#374151;font-size:14px;\">` + ($json.body.use_case || '—') + `</td></tr><tr><td style=\"padding:8px 12px;color:#6b7280;font-size:14px;\">ID</td><td style=\"padding:8px 12px;color:#9ca3af;font-size:12px;font-family:monospace;\">` + $json.body.reservation_id + `</td></tr></table><div style=\"margin-top:24px;text-align:center;\"><a href=\"https://tuagentestore.com/admin\" style=\"display:inline-block;background:#2563eb;color:#fff;font-size:14px;font-weight:700;padding:12px 28px;border-radius:8px;text-decoration:none;\">Ver en panel admin →</a></div></td></tr></table></body></html>` }}",
        "options": {
          "fromEmail": "={{ $env.GMAIL_FROM }}",
          "fromName": "TuAgente Store Ops"
        }
      },
      "id": "admin-alert",
      "name": "Email: Alerta Admin",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [700, 420],
      "credentials": {
        "gmailOAuth2": {
          "id": "EzOwUZC8g74ixDQC",
          "name": "Gmail OAuth2"
