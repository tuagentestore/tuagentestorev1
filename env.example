# ============================================================
# TUAGENTESTORE — Variables de Entorno (.env)
# COPIAR A .env Y COMPLETAR LOS VALORES
# NUNCA commitear este archivo al repo
# ============================================================

# ── GENERAL ──
NODE_ENV=production
DOMAIN=tuagentestore.com
APP_URL=https://tuagentestore.com
NEXT_PUBLIC_APP_URL=https://tuagentestore.com
N8N_SUBDOMAIN=n8n
N8N_WEBHOOK_BASE=https://n8n.srv1565607.hstgr.cloud

# ── DATABASE (PostgreSQL) ──
POSTGRES_USER=tuagentestore
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_32_CHARS
POSTGRES_DB=tuagentestore
DATABASE_URL=postgresql://tuagentestore:CAMBIAR_POR_PASSWORD_SEGURO_32_CHARS@postgres:5432/tuagentestore

# ── REDIS ──
REDIS_URL=redis://redis:6379

# ── AUTH (JWT) ──
JWT_SECRET=GENERAR_CON_openssl_rand_hex_64
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ── N8N ──
N8N_AUTH_USER=admin
N8N_AUTH_PASSWORD=CAMBIAR_PASSWORD_N8N_SEGURO

# ── STRIPE ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── MERCADOPAGO ──
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=...

# ── OPENAI / LLM ──
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-4o
OPENROUTER_API_KEY=sk-or-...

# ── EMAIL (Gmail OAuth2 via Google Workspace) ──
# Obtener en: console.cloud.google.com → APIs & Services → Credentials
# Scopes necesarios: gmail.send, spreadsheets, calendar
GOOGLE_CLIENT_ID=963201095086b122tdcdutclqc25os2b16fbn0hctns0.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REFRESH_TOKEN=1//048ue_tBOQLJRCgYIARAAGAQSNwF-L9IrOoZl_XMvVI6OlX3tz9K-c1yQDXRR8uYqsfOEuYAUKhZmZWPhOnIXD2yQsxS4WnJv2Wc
GMAIL_FROM=hola@tuagentestore.com
GMAIL_FROM_NAME=TuAgente Store
ADMIN_EMAIL=admin@tuagentestore.com

# ── GOOGLE SHEETS (CRM backup, mismo token OAuth que Gmail) ──
GOOGLE_SPREADSHEET_ID=...  # ID del Google Sheet master (de la URL del sheet)

# ── GOOGLE CALENDAR ──
GOOGLE_CALENDAR_ID=...  # ID del calendario (formato: xxx@group.calendar.google.com)

# ── CALENDLY ──
CALENDLY_API_KEY=...
CALENDLY_WEBHOOK_SIGNING_KEY=...

# ── WHATSAPP (BSP — si aplica) ──
WHATSAPP_BSP_API_URL=...
WHATSAPP_BSP_API_KEY=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_VERIFY_TOKEN=...

# ── ANALYTICS ──
GA4_MEASUREMENT_ID=G-...
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com

# ── SENTRY (Error tracking) ──
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=production

# ── ENCRYPTION (para credentials de clientes) ──
ENCRYPTION_KEY=GENERAR_CON_openssl_rand_hex_32

# ── WEBHOOK SECRETS ──
WEBHOOK_SECRET_INTERNAL=GENERAR_SECRETO_PARA_WEBHOOKS_INTERNOS

# ── HOSTINGER API (automatización infraestructura) ──
HOSTINGER_API_TOKEN=...

# ── UPSTASH REDIS (producción / cache de sesiones) ──
# Nota: el token incluido es read-only por diseño (JWT es source of truth)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── NEON POSTGRESQL (producción) ──
# Alternativa a PostgreSQL local en Docker
NEON_DATABASE_URL=postgresql://neondb_owner:...@ep-...neon.tech/neondb?sslmode=require

# ── FEATURE FLAGS ──
# Activar/desactivar secciones en producción
NEXT_PUBLIC_ENABLE_CASES=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_WIZARD=true
NEXT_PUBLIC_ENABLE_VERA_CHAT=true
NEXT_PUBLIC_WA_NUMBER=5493437527193
